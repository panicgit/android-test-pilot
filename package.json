{
  "name": "android-test-pilot",
  "version": "0.1.0",
  "description": "Android app test automation tool powered by Claude Code — static analysis, log coverage, and device testing with 3-tier strategy. Distributed as a Claude Code marketplace plugin.",
  "private": true,
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsc && chmod 755 lib/index.js",
    "prepare": "npm run build",
    "watch": "tsc --watch",
    "clean": "rm -rf lib",
    "test": "npx tsx --test test/**/*.test.ts",
    "bench": "npx tsx bench/run-bench.ts"
  },
  "keywords": [
    "android",
    "testing",
    "automation",
    "mcp",
    "claude-code",
    "logcat",
    "uiautomator"
  ],
  "license": "Apache-2.0",
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.26.0",
    "commander": "14.0.0",
    "express": "5.1.0",
    "fast-xml-parser": "5.5.7",
    "zod": "^4.1.13",
    "zod-to-json-schema": "3.25.0"
  },
  "optionalDependencies": {
    "@mobilenext/mobilecli": "0.1.60",
    "@types/pixelmatch": "^5.2.6",
    "@types/pngjs": "^6.0.5",
    "pixelmatch": "^7.1.0",
    "pngjs": "^7.0.0",
    "sharp": "^0.33.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.3",
    "@types/node": "^22.0.0",
    "typescript": "^5.8.0"
  }
}
